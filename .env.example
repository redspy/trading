# Core
PORT=4000
INTERNAL_API_KEY=replace-with-secure-key
DATABASE_PATH=./trading.sqlite
PAPER_MODE=true
LIVE_MODE=false
KILL_SWITCH=true
RISK_PER_TRADE_PCT=0.005
DAILY_LOSS_LIMIT_PCT=0.02
FIXED_STOP_LOSS_PCT=0.025
MAX_POSITIONS=5
ACCOUNT_EQUITY=100000000
WATCHLIST=005930,069500

# KIS
KIS_APP_KEY=your-app-key
KIS_APP_SECRET=your-app-secret
KIS_ACCOUNT_NUMBER=your-account-number
KIS_PRODUCT_CODE=01
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_WS_URL=wss://openapi.koreainvestment.com:21000

# Collector
CORE_BASE_URL=http://localhost:4000
