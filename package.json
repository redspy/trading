{
  "name": "trading",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev:core": "npm run -w @trading/core dev",
    "dev:collector": "npm run -w @trading/collector dev",
    "dev:web": "npm run -w @trading/web-ui dev",
    "test": "npm run build && npm run -w @trading/core test",
    "lint": "npm run -ws lint"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
